# Nightly Lightning Lane collector (ILL + park MLL/LLPP) — America/New_York
# Install with: ./update-ll-collector.sh --install-cron
#
# Runs at 11:00 PM Eastern every day (adjust INSTALL_DIR if needed).
0 23 * * * . /opt/hurryupandwait/scripts/env.ll-collector && cd /opt/hurryupandwait/scripts && /usr/bin/python3 collect_ill_daily.py >> /var/log/hurryupandwait-ll-collector.log 2>&1